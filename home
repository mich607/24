<body>
<!DOCTYPE html>
<html>
<head>
    <title>CSS Types Example</title>

    <!-- Internal CSS -->
    <style>
        .internal-paragraph {
            color: orange;
            font-weight: bold;
        }

        .internal-h1 {
            color: green;
        }

        .internal-h3 {
            color: brown;
        }
    </style>

    <!-- External CSS -->
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <!-- PARAGRAPHS -->

    <p style="color: blue; font-style: italic;">
        Paragraph 1 (Inline CSS)
    </p>

    <p class="internal-paragraph">
        Paragraph 2 (Internal CSS)
    </p>

    <p class="external-paragraph">
        Paragraph 3 (External CSS)
    </p>


    <!-- H1 -->

    <h1 style="color: red;">
        Highlight 1 (Inline CSS)
    </h1>

    <h1 class="internal-h1">
        Highlight 2 (Internal CSS)
    </h1>

    <h1 class="external-h1">
        Highlight 3 (External CSS)
    </h1>


    <!-- H3 -->

    <h3 style="color: purple;">
        Building 1 (Inline CSS)
    </h3>

    <h3 class="internal-h3">
        Building 2 (Internal CSS)
    </h3>

    <h3 class="external-h3">
        Building 3 (External CSS)
    </h3>

</body>
</html>

</body>
</html>
